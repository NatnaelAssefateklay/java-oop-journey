{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "javac: build",
      "type": "shell",
      "command": "javac",
      "args": [
        "-d",
        "bin",
        "src/*.java"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$javac"]
    }
  ]
}
